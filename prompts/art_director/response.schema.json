{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meridian.report/schema/art-director-v2-response.json",
  "title": "ArtDirectorV2Response",
  "type": "object",
  "required": ["slides_storyboard"],
  "properties": {
    "slides_storyboard": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/StoryboardSlide" }
    }
  },
  "$defs": {
    "Recipe": {
      "type": "string",
      "enum": [
        "hero_number",
        "slope_graph",
        "dumbbell",
        "diverging_bars",
        "lollipop",
        "bullet_chart",
        "grouped_bar",
        "stacked_bars",
        "single_stacked_bar",
        "marimekko",
        "index_chart",
        "connected_scatter",
        "moving_average",
        "fan_chart",
        "streamgraph",
        "stacked_area",
        "area_line_custom",
        "horizon_chart",
        "sparkline_grid",
        "small_multiples_area",
        "beeswarm",
        "dot_plot",
        "barcode",
        "strip_plot",
        "histogram",
        "box_plot",
        "qq_plot",
        "ridgeline",
        "waffle_grid",
        "survey_waffle",
        "warming_stripes",
        "calendar_heatmap",
        "dot_heatmap",
        "hex_bin",
        "contour_density",
        "treemap",
        "arc_concentration",
        "arc_diagram",
        "choropleth",
        "spike_map"
      ]
    },
    "NarrativeTag": {
      "type": "string",
      "enum": [
        "scale_surprise",
        "slope",
        "trajectory",
        "divergence",
        "concentration",
        "composition",
        "hierarchy",
        "ranking",
        "peer_gap",
        "correlation",
        "distribution",
        "duration",
        "seasonality",
        "anomaly",
        "threshold_breach",
        "milestone",
        "geography",
        "flow"
      ]
    },
    "StoryboardSlide": {
      "type": "object",
      "required": [
        "id",
        "source_insight_ids",
        "recipe",
        "narrative_tag",
        "story",
        "headline",
        "required_data_paths",
        "footnote"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "maxLength": 60
        },
        "source_insight_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "type": "string" }
        },
        "recipe": { "$ref": "#/$defs/Recipe" },
        "secondary_recipe": { "$ref": "#/$defs/Recipe" },
        "narrative_tag": { "$ref": "#/$defs/NarrativeTag" },
        "story": {
          "type": "string",
          "minLength": 40,
          "maxLength": 700
        },
        "reformulation_notes": {
          "type": "string",
          "maxLength": 800
        },
        "headline": {
          "type": "string",
          "minLength": 8,
          "maxLength": 200
        },
        "subhead": {
          "type": "string",
          "maxLength": 240
        },
        "kpis": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["label", "path", "format"],
            "properties": {
              "label": { "type": "string", "minLength": 1, "maxLength": 60 },
              "path": { "type": "string", "minLength": 1, "maxLength": 200 },
              "format": {
                "type": "string",
                "enum": [
                  "pct",
                  "aed_bn",
                  "aed_mn",
                  "aed_k",
                  "pct_pp",
                  "signed_pct",
                  "x",
                  "int",
                  "num",
                  "year",
                  "usc_kwh",
                  "date_long",
                  "date_short",
                  "string"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "required_data_paths": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 20,
          "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "color_emphasis": {
          "type": "string",
          "maxLength": 300
        },
        "footnote": {
          "type": "string",
          "minLength": 8,
          "maxLength": 300
        }
      },
      "additionalProperties": false
    }
  }
}
